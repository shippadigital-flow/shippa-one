# Environment example

This file lists non-sensitive environment variables used by the application. Copy this file to `.env` or set variables in your deployment environment.

# NODE / runtime
NODE_ENV=development

# Base public URL
VITE_PUBLIC_URL=

# API endpoints
VITE_API_URL=https://api.example.com

# Feature flags
VITE_ENABLE_ANALYTICS=false

# Optional: Sentry / error tracking (replace with real DSN in production)
VITE_SENTRY_DSN=

# Any CI/CD or platform-specific variables (e.g., cloudflare)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

